# Copy this file to `.env.local` or `.env` and fill in your real Gemini API key.
# GitRoast checks `.env.local` first, then `.env`, then inherited shell env vars.

GEMINI_API_KEY=your_gemini_api_key_here
GITROAST_GEMINI_MODEL=gemini-2.5-flash

# Alternative key name also supported by GitRoast:
# GOOGLE_API_KEY=your_gemini_api_key_here

# Supported model values:
# GITROAST_GEMINI_MODEL=gemini-2.5-flash
# GITROAST_GEMINI_MODEL=gemini-2.5-pro
# GITROAST_GEMINI_MODEL=gemini-2.5-flash-lite
#
# Alternate model env key also supported:
# GEMINI_MODEL=gemini-2.5-pro
